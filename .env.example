# ============================================================
# Goodfill Care - Samui Wellness Platform
# Copy this file to .env.local and fill in your values
# ============================================================

# --- Google Gemini (AI assessment + package recommendation) ---
# Get your key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# --- Supabase (SQL database) ---
# Project URL and keys from https://supabase.com/dashboard -> Project Settings -> API
# If these are left empty, the app falls back to an in-memory store (demo mode).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Auth (account sign-in session signing) ---
# Secret used to sign the session cookie. REQUIRED in production — the
# server refuses to start without it; in dev a fallback keeps demo mode working.
# Generate one with:  openssl rand -hex 32
AUTH_SECRET=

# --- LINE (expert consultation: Messaging API push + LIFF) ---
# From the LINE Developers console for the expert OA channel.
# SECRETS — keep server-side, never commit real values:
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
# Not secret (used for reference / client):
LINE_CHANNEL_ID=2008409511
# LIFF app ids (public — used client-side to open the LIFF):
NEXT_PUBLIC_LIFF_MANAGED_PLAN_ID=2008409515-L8LJCmkc
NEXT_PUBLIC_LIFF_CHAT_ID=2008409515-rgKMDQBb

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Access code for the expert console at /expert (nutritionist / doctor)
EXPERT_ACCESS_CODE=samui-expert
